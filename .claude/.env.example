# PAI-DOTS Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to version control

# Optional: Override the default DOTS directory (~/.claude)
# DOTS_DIR=/path/to/your/.claude

# Optional: Enable debug logging for hooks
# DEBUG_HOOKS=1

# Optional: API keys for skills that need them
# ANTHROPIC_API_KEY=your_key_here
# ELEVENLABS_API_KEY=your_key_here
